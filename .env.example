# Copy this file to .env and fill in real values.
# NEVER commit .env — it is in .gitignore.

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://tripuser:trippass@localhost:5432/tripplanner

# ── Redis / Celery ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Internal Auth ──────────────────────────────────────────────────────────────
# Must be at least 32 random characters — used for bot→API calls (X-API-Key header)
INTERNAL_API_KEY=change-me-at-least-32-chars-random

# ── Telegram ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── S3 / Cloudflare R2 ─────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_BUCKET_NAME=trip-planner-docs
# For Cloudflare R2: https://your-account.r2.cloudflarestorage.com
# For real AWS S3: leave empty or remove this line
AWS_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com
AWS_REGION=auto

# ── Observability ──────────────────────────────────────────────────────────────
SENTRY_DSN=https://your_key@sentry.io/your_project

# ── Bot → API ──────────────────────────────────────────────────────────────────
# Inside docker-compose the API service is named "api". Change to
# http://localhost:8000 when running the bot outside docker-compose.
API_BASE_URL=http://api:8000

# ── App ────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Recommendation Provider ────────────────────────────────────────────────────
# stub = synthetic data (dev/test, no API key needed)
# google_places = real data via Google Places API
RECOMMENDATION_PROVIDER=stub
# Required only when RECOMMENDATION_PROVIDER=google_places:
GOOGLE_PLACES_API_KEY=
